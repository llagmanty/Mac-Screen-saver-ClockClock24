{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Screensaver",
            "type": "shell",
            "command": "swiftc",
            "args": [
                "-emit-library",
                "-o",
                "${workspaceFolder}/ClockClock24.saver/Contents/MacOS/ClockClock24",
                "${workspaceFolder}/ClockClock24View.swift",
                "-framework",
                "ScreenSaver",
                "-framework",
                "Cocoa"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$swiftc"
        },
        {
            "label": "Install Screensaver",
            "type": "shell",
            "command": "cp",
            "args": [
                "-r",
                "${workspaceFolder}/ClockClock24.saver",
                "${env:HOME}/Library/Screen Savers/"
            ],
            "dependsOn": "Build Screensaver",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
